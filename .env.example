# ═══════════════════════════════════════════════════════════
#  Pac-Man Retrô v3.0 — Variáveis de Ambiente
#  ═══════════════════════════════════════════════════════════
#
#  Instruções:
#    1. Copie este arquivo para .env
#       cp .env.example .env
#
#    2. Preencha os valores (especialmente RESET_SCORE_TOKEN!)
#
#    3. Execute com Docker Compose:
#       docker compose up -d --build
#
#  ═══════════════════════════════════════════════════════════

# ── Servidor ───────────────────────────────────────────────

# Porta onde o servidor FastAPI será executado
PORT=8000

# Caminho para o arquivo do banco SQLite
DB_PATH=./data/pacman.db

# ── CORS ────────────────────────────────────────────────────

# Origens permitidas para CORS (separadas por vírgula, sem espaços).
# Padrão: * (qualquer origem)
# Exemplo: https://pacman.seudominio.com,https://meuapp.com
# Para restringir a mesma origem (mais seguro), deixe vazio:
#   ALLOWED_ORIGINS=
#
ALLOWED_ORIGINS=*

# ── Administração ──────────────────────────────────────────

# ╔══════════════════════════════════════════════════════════╗
# ║  ⚠️  ATENÇÃO — OBRIGATÓRIO ALTERAR PARA PRODUÇÃO!     ║
# ╚══════════════════════════════════════════════════════════╝
#
# Token secreto usado pelo endpoint administrativo /api/reset-score.
# Este token permite ZERAR O RANKING e DESLOGAR TODOS OS JOGADORES.
#
# Requisitos de segurança:
#   - Mínimo 20 caracteres alfanuméricos
#   - Misturar maiúsculas, minúsculas e números
#   - NÃO usar o valor padrão 'mudar123' em produção
#   - NUNCA commitar o token real no repositório
#   - Armazenar em gerenciador de segredos (ex: 1Password, Vault)
#
# Gere um token seguro com:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Exemplo (use um valor diferente em produção!):
# RESET_SCORE_TOKEN=seu-token-aqui-mude-para-producao
#
# Com Docker Compose, pode ser passado via .env na raiz do projeto:
#   echo "RESET_SCORE_TOKEN=$(python3 -c 'import secrets; print(secrets.token_urlsafe(32))')" >> .env
#   docker compose up -d
#
# ⚠️  Em produção, o docker-compose.yml exige esta variável.
#     Se não for definida, o endpoint /api/reset-score retornará erro.
#     Gere um token seguro com o comando acima e cole aqui.
#
RESET_SCORE_TOKEN=ColoqueSeuTokenAqui
